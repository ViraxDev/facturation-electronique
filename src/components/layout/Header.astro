---
import { Menu } from "lucide-react";
const path = Astro.url.pathname;
const navItems = [
  { href: "/pour-comptables", label: "Pour les cabinets" },
  { href: "/offres", label: "Offres" },
  { href: "/ressources", label: "Ressources" },
  { href: "/academy", label: "Academy" },
  { href: "/a-propos", label: "À propos" },
];
---
<header class="sticky top-0 z-50 bg-glass border-b border-[var(--color-border)]">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 h-14 sm:h-16 flex items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2 font-semibold text-[var(--color-primary)]" aria-label="Facturation Électronique 2026 — Accueil">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-sky-600 to-sky-500 text-white text-sm">FE</span>
      <span class="hidden sm:inline">Facturation&nbsp;Électronique</span>
      <span class="sm:hidden">FE 2026</span>
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Navigation principale">
      {navItems.map((i) => (
        <a
          href={i.href}
          class:list={["px-3 py-2 rounded-lg text-sm font-medium transition-colors hover:bg-[var(--color-muted)]", path.startsWith(i.href) ? "text-[var(--color-accent)]" : "text-[var(--color-secondary)]"]}
          aria-current={path.startsWith(i.href) ? "page" : undefined}
        >{i.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a href="/contact" class="hidden sm:inline-flex btn-primary rounded-lg px-3 sm:px-4 py-2 text-sm font-semibold shadow-sm">Prendre RDV</a>
      <button
        id="mobile-nav-toggle"
        class="md:hidden inline-flex h-10 w-10 items-center justify-center rounded-lg border border-[var(--color-border)] bg-white"
        aria-label="Ouvrir le menu"
        aria-controls="mobile-nav"
        aria-expanded="false"
      ><Menu className="h-5 w-5" aria-hidden="true" /></button>
    </div>
  </div>

  <div id="mobile-nav" hidden class="md:hidden border-t border-[var(--color-border)] bg-[var(--color-card)]">
    <nav class="px-4 py-3 flex flex-col gap-1" aria-label="Navigation mobile">
      {navItems.map((i) => (
        <a href={i.href} class="px-3 py-3 rounded-lg text-base font-medium hover:bg-[var(--color-muted)]">{i.label}</a>
      ))}
      <a href="/contact" class="mt-2 btn-primary rounded-lg px-4 py-3 text-center text-base font-semibold">Prendre RDV</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-nav-toggle");
  const panel = document.getElementById("mobile-nav");
  btn?.addEventListener("click", () => {
    const open = panel?.hasAttribute("hidden");
    if (open) panel?.removeAttribute("hidden");
    else panel?.setAttribute("hidden", "");
    btn.setAttribute("aria-expanded", String(!!open));
  });
</script>

---
export interface Props { value: string; label: string; sublabel?: string }
const { value, label, sublabel } = Astro.props;
---
<div class="not-prose my-6 rounded-2xl border border-[var(--color-border)] bg-gradient-to-br from-sky-50 to-white p-6 text-center">
  <div class="text-4xl sm:text-5xl font-bold tabular text-[var(--color-primary)]">{value}</div>
  <div class="mt-2 text-sm font-medium text-[var(--color-secondary)]">{label}</div>
  {sublabel && <div class="mt-1 text-xs text-[var(--color-muted-foreground)]">{sublabel}</div>}
</div>

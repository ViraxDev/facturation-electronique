---
import BaseLayout from "./BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import XPBar from "@/components/academy/XPBar";
import Quiz from "@/components/academy/Quiz";
import ModuleFooter from "@/components/academy/ModuleFooter";
import { getCollection, getEntry, type CollectionEntry } from "astro:content";
import { Clock, Award, Target } from "lucide-react";

export interface Props { entry: CollectionEntry<"modules"> }
const { entry } = Astro.props;
const { data, slug } = entry;

const all = await getCollection("modules");
const siblings = all
  .filter((m) => m.data.parcours === data.parcours)
  .sort((a, b) => a.data.order - b.data.order);
const idx = siblings.findIndex((m) => m.slug === slug);
const prev = idx > 0 ? siblings[idx - 1] : null;
const next = idx >= 0 && idx < siblings.length - 1 ? siblings[idx + 1] : null;
const toNav = (m: CollectionEntry<"modules"> | null) =>
  m ? { slug: m.slug, title: m.data.title, order: m.data.order } : null;

const parcoursEntry = await getEntry("parcours", data.parcours);
const parcoursTitle = parcoursEntry?.data.titre ?? data.parcours;
---
<BaseLayout seo={{ title: data.title, description: data.summary ?? data.objectives.join(" · "), type: "article" }}>
  <Header />
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-4">
    <XPBar client:load />
  </div>

  <main id="main" class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-8">
    <nav class="text-sm text-[var(--color-muted-foreground)] mb-4" aria-label="Fil d'ariane">
      <a href="/academy" class="hover:text-[var(--color-accent)]">Academy</a>
      <span aria-hidden="true"> / </span>
      <a href={`/academy/parcours/${data.parcours}`} class="hover:text-[var(--color-accent)]">{parcoursTitle}</a>
    </nav>

    <header class="mb-8">
      <div class="flex flex-wrap items-center gap-3 text-xs font-medium text-[var(--color-muted-foreground)] mb-3">
        <span class="inline-flex items-center gap-1.5 rounded-full bg-[var(--color-muted)] px-2.5 py-1">
          <Clock className="h-3.5 w-3.5" aria-hidden="true" /> {data.duration} min
        </span>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-100 text-amber-900 px-2.5 py-1">
          <Award className="h-3.5 w-3.5" aria-hidden="true" /> {data.xp} XP
        </span>
        <span class="rounded-full bg-sky-100 text-sky-900 px-2.5 py-1">Module {data.order}</span>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-primary)] tracking-tight">{data.title}</h1>
      {data.objectives.length > 0 && (
        <div class="mt-6 rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] p-4">
          <h2 class="text-sm font-semibold text-[var(--color-primary)] flex items-center gap-2 mb-2"><Target className="h-4 w-4" aria-hidden="true"/>Objectifs</h2>
          <ul class="space-y-1 text-sm">
            {data.objectives.map((o) => <li>• {o}</li>)}
          </ul>
        </div>
      )}
    </header>

    <article class="prose prose-slate max-w-none prose-headings:text-[var(--color-primary)] prose-a:text-[var(--color-accent)]">
      <slot />
    </article>

    {data.sources.length > 0 && (
      <section class="mt-10 pt-6 border-t border-[var(--color-border)]">
        <h2 class="text-sm font-semibold text-[var(--color-primary)] mb-3">Sources officielles</h2>
        <ul class="space-y-1 text-sm">
          {data.sources.map((src) => (
            <li><a class="text-[var(--color-accent)] hover:underline" href={src.url} target="_blank" rel="noopener">{src.label} ↗</a></li>
          ))}
        </ul>
      </section>
    )}

    {data.quiz.length > 0 && (
      <section class="mt-10">
        <Quiz slug={slug} moduleTitle={data.title} xp={data.xp} questions={data.quiz} client:visible />
      </section>
    )}

    <ModuleFooter
      slug={slug}
      xp={data.xp}
      prev={toNav(prev)}
      next={toNav(next)}
      parcoursId={data.parcours}
      parcoursTitle={parcoursTitle}
      client:load
    />
  </main>
  <Footer />
</BaseLayout>

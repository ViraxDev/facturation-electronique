---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
---
<MarketingLayout seo={{ title: "Contact", description: "Demandez une démo ou un audit gratuit." }}>
  <section class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 py-12">
    <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-primary)]">Contact</h1>
    <p class="mt-3 text-[var(--color-muted-foreground)]">Réponse sous 24h ouvrées.</p>
    <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/merci" class="mt-8 space-y-5">
      <input type="hidden" name="form-name" value="contact" />
      <p class="hidden"><label>Ne pas remplir : <input name="bot-field" /></label></p>
      <div>
        <label for="name" class="block text-sm font-medium mb-1">Nom <span aria-hidden="true" class="text-red-600">*</span></label>
        <input id="name" name="name" required class="w-full rounded-lg border border-[var(--color-border)] bg-white px-3 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]" />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium mb-1">Email <span aria-hidden="true" class="text-red-600">*</span></label>
        <input id="email" type="email" name="email" required autocomplete="email" class="w-full rounded-lg border border-[var(--color-border)] bg-white px-3 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]" />
      </div>
      <div>
        <label for="cabinet" class="block text-sm font-medium mb-1">Cabinet</label>
        <input id="cabinet" name="cabinet" class="w-full rounded-lg border border-[var(--color-border)] bg-white px-3 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]" />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium mb-1">Message <span aria-hidden="true" class="text-red-600">*</span></label>
        <textarea id="message" name="message" required rows="5" class="w-full rounded-lg border border-[var(--color-border)] bg-white px-3 py-2.5 text-base focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]"></textarea>
      </div>
      <button type="submit" class="btn-primary rounded-lg px-5 py-3 text-sm font-semibold">Envoyer</button>
    </form>
  </section>
</MarketingLayout>

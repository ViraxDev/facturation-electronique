---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import { ArrowRight, Check, X, Quote } from "lucide-react";

const painPoints = [
  { strong: "Clients perdus", rest: "qui vont chez le concurrent déjà « Factur-X ready »." },
  { strong: "Ré-saisie manuelle", rest: "des factures reçues en PDF non conformes." },
  { strong: "Explication à répéter", rest: "à des clients qui n'ouvrent pas leurs e-mails." },
  { strong: "Aucun argumentaire structuré", rest: "pour packager l'offre et facturer le setup." },
];

const testimonials = [
  { initials: "MD", quote: "On a équipé 112 clients en 4 mois. La plateforme a fait tout le travail ; on a juste accompagné.", name: "Marine Deville", role: "Cabinet Deville & associés · Lyon · 180 clients" },
  { initials: "PL", quote: "Le simulateur d'éligibilité, on l'utilise en rendez-vous commercial. Ça convainc en 2 minutes.", name: "Pierre Lamy", role: "Lamy Conseil · Bordeaux · 45 clients" },
  { initials: "SB", quote: "Les certifications Academy motivent les collaborateurs. Turnover divisé par deux cette année.", name: "Sophie Benhamou", role: "BGC Experts · Paris · 320 clients" },
];
---
<MarketingLayout seo={{ title: "Facturation Électronique 2026 — Plateforme pour cabinets d'experts-comptables", description: "Transformez l'obligation 1ᵉʳ septembre 2026 en levier de revenus récurrents." }}>
  <section class="bg-hero-sky">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-16 pb-24 text-center">
      <span class="eyebrow">Réforme 1ᵉʳ septembre 2026</span>
      <h1 class="mt-5 text-[40px] sm:text-5xl lg:text-6xl font-bold tracking-[-0.025em] text-[var(--color-primary)] leading-[1.04] max-w-4xl mx-auto">
        Maîtrisez la réforme.<br/><span class="text-gradient-sky">Équipez vos clients.</span>
      </h1>
      <p class="mt-5 text-lg sm:text-xl text-[var(--color-muted-foreground)] max-w-xl mx-auto leading-snug">
        La plateforme complète pour les cabinets d'experts-comptables qui veulent transformer l'obligation Factur-X en levier de revenus récurrents.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/contact" class="btn-primary inline-flex items-center gap-2 rounded-xl px-6 py-3.5 text-sm font-semibold">Démarrer l'essai gratuit <ArrowRight className="h-4 w-4" aria-hidden="true"/></a>
        <a href="/offres" class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-border)] bg-white px-6 py-3.5 text-sm font-semibold hover:bg-[var(--color-muted)]">Voir une démo</a>
      </div>
      <div class="mt-10 inline-flex flex-wrap gap-6 rounded-2xl bg-white border border-[var(--color-border)] px-6 py-3.5 shadow-[var(--shadow-card)]">
        <div class="flex items-center gap-2.5">
          <span class="text-sm font-bold tabular text-[var(--color-accent)]">1ᵉʳ sept. 2026</span>
          <span class="text-xs text-[var(--color-muted-foreground)]">Réception universelle</span>
        </div>
        <div class="hidden sm:block w-px bg-[var(--color-border)]"></div>
        <div class="flex items-center gap-2.5">
          <span class="text-sm font-bold tabular text-[var(--color-accent)]">1ᵉʳ sept. 2027</span>
          <span class="text-xs text-[var(--color-muted-foreground)]">Émission PME/TPE</span>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">Pour les cabinets qui refusent de subir 2026.</h2>
      <p class="mt-3 text-lg text-[var(--color-muted-foreground)]">Pendant que vos confrères improvisent, vous industrialisez la conformité de vos 150 clients — et vous facturez la valeur ajoutée.</p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-[1.1fr_0.9fr] gap-5">
      <div class="rounded-[20px] border border-[var(--color-border)] bg-white p-7 shadow-[var(--shadow-subtle)]">
        <h3 class="text-xl font-bold text-[var(--color-primary)]">Les points de friction vécus par 78 % des cabinets</h3>
        <ul class="mt-5 space-y-3">
          {painPoints.map((p) => (
            <li class="flex gap-3 items-start text-[15px]">
              <span class="flex-shrink-0 mt-0.5 inline-flex h-[22px] w-[22px] items-center justify-center rounded-full bg-red-50 text-red-600"><X className="h-3 w-3" aria-hidden="true" strokeWidth={3}/></span>
              <span><strong>{p.strong}</strong> {p.rest}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-[20px] bg-navy-deep text-white p-7">
        <h3 class="text-xl font-bold text-white">Projection revenus</h3>
        <div class="mt-5">
          <div class="text-[56px] font-bold tracking-[-0.03em] tabular leading-none text-gradient-xp">+120 k€</div>
          <div class="mt-2 text-sm text-slate-400">de MRR cumulé / an pour un cabinet moyen (150 clients × 68 €/mois)</div>
        </div>
        <ul class="mt-6 space-y-2 text-sm text-slate-300">
          <li class="flex gap-2.5 items-center"><Check className="h-3.5 w-3.5 text-emerald-400 flex-shrink-0" aria-hidden="true"/> Portail client prêt à l'emploi</li>
          <li class="flex gap-2.5 items-center"><Check className="h-3.5 w-3.5 text-emerald-400 flex-shrink-0" aria-hidden="true"/> Argumentaire commercial clé en main</li>
          <li class="flex gap-2.5 items-center"><Check className="h-3.5 w-3.5 text-emerald-400 flex-shrink-0" aria-hidden="true"/> Certifications gratuites pour vos collaborateurs</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">Ils ont équipé leurs clients avant le 1ᵉʳ septembre.</h2>
      <p class="mt-3 text-lg text-[var(--color-muted-foreground)]">Trois cabinets, trois tailles — un même résultat : aucune perte de client, du revenu récurrent en plus.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {testimonials.map((t) => (
        <figure class="rounded-2xl border border-[var(--color-border)] bg-white p-6">
          <blockquote class="text-[15px] leading-snug font-medium text-[var(--color-primary)] before:content-['«_'] before:text-[var(--color-accent)] before:font-bold after:content-['_»'] after:text-[var(--color-accent)] after:font-bold">{t.quote}</blockquote>
          <figcaption class="mt-5 pt-4 border-t border-[var(--color-border)] flex gap-3 items-center">
            <div class="h-[38px] w-[38px] rounded-full bg-gradient-to-br from-[#0369A1] to-[#0284C7] text-white flex items-center justify-center font-bold text-[13px]">{t.initials}</div>
            <div>
              <div class="text-[13px] font-bold text-[var(--color-primary)]">{t.name}</div>
              <div class="text-xs text-[var(--color-muted-foreground)]">{t.role}</div>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-20">
    <div class="bg-navy-deep text-white rounded-[28px] px-8 sm:px-12 py-14 text-center">
      <h2 class="text-3xl sm:text-4xl font-bold text-white max-w-2xl mx-auto">Mettez votre cabinet en conformité. Et en position de vendre.</h2>
      <p class="mt-4 text-lg text-slate-400 max-w-xl mx-auto">Essai gratuit 30 jours, sans carte bancaire. Migration assistée sur vos 30 premiers clients offerte.</p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        <a href="/contact" class="btn-primary inline-flex items-center gap-2 rounded-xl px-6 py-3.5 text-sm font-semibold">Démarrer maintenant <ArrowRight className="h-4 w-4" aria-hidden="true"/></a>
        <a href="/contact" class="inline-flex items-center gap-2 rounded-xl border border-slate-700 px-6 py-3.5 text-sm font-semibold text-white hover:bg-slate-800">Parler à un conseiller</a>
      </div>
    </div>
  </section>
</MarketingLayout>

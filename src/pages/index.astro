---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import { Calendar, ShieldCheck, Zap, ArrowRight, CheckCircle2 } from "lucide-react";
---
<MarketingLayout seo={{ title: "Facturation Électronique 2026 — Le guide de référence pour les cabinets", description: "Réforme obligatoire au 1er septembre 2026. Formez vos équipes, équipez vos clients et monétisez le chantier." }}>
  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 sm:py-24">
      <div class="max-w-3xl">
        <span class="inline-flex items-center gap-2 rounded-full bg-sky-100 text-sky-900 px-3 py-1 text-xs font-semibold">
          <Calendar className="h-3.5 w-3.5" aria-hidden="true" /> Obligation : 1ᵉʳ septembre 2026
        </span>
        <h1 class="mt-5 text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-[var(--color-primary)]">
          La facturation électronique,<br/>enfin maîtrisée.
        </h1>
        <p class="mt-5 text-lg sm:text-xl text-[var(--color-secondary)] max-w-2xl">
          Un wiki expert gamifié + une offre packagée pour les cabinets d'experts-comptables. Comprenez la réforme, formez vos équipes, équipez vos clients.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/pour-comptables" class="btn-primary inline-flex items-center gap-2 rounded-lg px-5 py-3 text-sm font-semibold">
            Offre cabinets <ArrowRight className="h-4 w-4" aria-hidden="true"/>
          </a>
          <a href="/academy" class="inline-flex items-center gap-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-card)] px-5 py-3 text-sm font-semibold hover:bg-[var(--color-muted)]">
            Explorer l'Academy
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-card)] border-y border-[var(--color-border)]">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16 grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        { Icon: ShieldCheck, title: "Cadre légal décrypté", text: "Ordonnance 2021-1190, décrets, sanctions DGFiP — tout en clair." },
        { Icon: Zap, title: "Technique approfondie", text: "Factur-X, UBL, CII, EN 16931, profils, statuts, intégration ERP." },
        { Icon: CheckCircle2, title: "Business concret", text: "Offre packagée TPE/PME, pricing, ROI cabinet, contrat type." },
      ].map(({ Icon, title, text }) => (
        <div class="rounded-2xl border border-[var(--color-border)] bg-white p-6">
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-xl bg-sky-100 text-sky-700">
            <Icon className="h-5 w-5" aria-hidden="true" />
          </div>
          <h3 class="mt-4 text-lg font-semibold text-[var(--color-primary)]">{title}</h3>
          <p class="mt-2 text-sm text-[var(--color-muted-foreground)]">{text}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="rounded-2xl bg-gradient-to-br from-[var(--color-primary)] to-slate-800 text-white p-8 sm:p-12 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold">Prêt à équiper votre cabinet ?</h2>
      <p class="mt-3 text-slate-200">Démo 30 min : audit, offre pilote, tarifs.</p>
      <a href="/contact" class="mt-6 inline-flex items-center gap-2 rounded-lg bg-white text-[var(--color-primary)] px-5 py-3 text-sm font-semibold hover:bg-slate-100">
        Prendre rendez-vous <ArrowRight className="h-4 w-4" aria-hidden="true"/>
      </a>
    </div>
  </section>
</MarketingLayout>

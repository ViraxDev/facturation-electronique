---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import { CheckCircle2 } from "lucide-react";
---
<MarketingLayout seo={{ title: "Merci", description: "Votre message a bien été reçu." }}>
  <section class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8 py-24 text-center">
    <CheckCircle2 className="mx-auto h-14 w-14 text-emerald-600" aria-hidden="true" />
    <h1 class="mt-6 text-3xl font-bold text-[var(--color-primary)]">Message reçu</h1>
    <p class="mt-3 text-[var(--color-muted-foreground)]">Nous revenons vers vous sous 24h ouvrées.</p>
    <a href="/" class="mt-8 inline-flex items-center gap-2 rounded-lg bg-[var(--color-primary)] text-white px-5 py-3 text-sm font-semibold">Retour à l'accueil</a>
  </section>
</MarketingLayout>

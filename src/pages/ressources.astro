---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import { FileText, BookOpen, Wrench, ArrowRight } from "lucide-react";

const items = [
  { href: "/academy", Icon: BookOpen, title: "Academy — 30 modules", text: "Parcours pédagogique gamifié sur 5 parcours (fondations, écosystème, technique, e-reporting, business)." },
  { href: "/academy/outils", Icon: Wrench, title: "4 outils interactifs", text: "Simulateur d'éligibilité, comparateur PA, calculateur ROI, visualiseur Factur-X." },
  { href: "/academy/lexique", Icon: FileText, title: "Lexique (40 termes)", text: "PA, OD, PPF, Factur-X, EN 16931, flux Y — définitions expertes." },
  { href: "/academy/veille", Icon: FileText, title: "Timeline de la réforme", text: "De 2019 à 2027, tous les jalons législatifs et techniques." },
];
---
<MarketingLayout seo={{ title: "Ressources", description: "Academy, outils, lexique, veille : tout pour maîtriser la réforme." }}>
  <section class="bg-hero-sky">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-16 pb-10">
      <span class="eyebrow">Ressources gratuites</span>
      <h1 class="mt-5 text-[40px] sm:text-5xl font-bold tracking-[-0.025em] text-[var(--color-primary)] leading-[1.05]">Tout pour <span class="text-gradient-sky">maîtriser la réforme.</span></h1>
      <p class="mt-4 text-lg text-[var(--color-muted-foreground)] max-w-xl">Academy gamifiée, outils interactifs, lexique, veille législative — en accès libre.</p>
    </div>
  </section>
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {items.map(({ href, Icon, title, text }) => (
        <li>
          <a href={href} class="group block rounded-2xl border border-[var(--color-border)] bg-white p-6 shadow-[var(--shadow-subtle)] hover:shadow-[var(--shadow-card)] transition-all hover:-translate-y-0.5">
            <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-gradient-to-br from-[#0369A1] to-[#0284C7] text-white"><Icon className="h-5 w-5" aria-hidden="true"/></div>
            <h2 class="mt-4 text-lg font-bold text-[var(--color-primary)] group-hover:text-[var(--color-accent)] transition-colors">{title}</h2>
            <p class="mt-2 text-sm text-[var(--color-muted-foreground)] leading-snug">{text}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-bold text-[var(--color-accent)] group-hover:translate-x-0.5 transition-transform">Ouvrir <ArrowRight className="h-3.5 w-3.5" aria-hidden="true"/></span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</MarketingLayout>

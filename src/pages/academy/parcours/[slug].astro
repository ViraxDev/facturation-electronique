---
import { getCollection, getEntry } from "astro:content";
import AcademyLayout from "@/layouts/AcademyLayout.astro";
import ModuleCard from "@/components/academy/ModuleCard.astro";

export async function getStaticPaths() {
  const parcours = await getCollection("parcours");
  return parcours.map((p) => ({ params: { slug: p.data.id }, props: { id: p.data.id } }));
}

const { id } = Astro.props;
const parcoursEntry = await getEntry("parcours", id);
if (!parcoursEntry) throw new Error(`Parcours not found: ${id}`);
const modules = (await getCollection("modules", (m) => m.data.parcours === id)).sort((a, b) => a.data.order - b.data.order);
---
<AcademyLayout seo={{ title: parcoursEntry.data.titre, description: parcoursEntry.data.description }}>
  <nav class="text-sm text-[var(--color-muted-foreground)] mb-4" aria-label="Fil d'ariane">
    <a href="/academy" class="hover:text-[var(--color-accent)]">Academy</a>
    <span aria-hidden="true"> / </span>
    <span>{parcoursEntry.data.titre}</span>
  </nav>
  <header class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-primary)] tracking-tight">{parcoursEntry.data.titre}</h1>
    <p class="mt-3 text-lg text-[var(--color-muted-foreground)] max-w-3xl">{parcoursEntry.data.description}</p>
  </header>
  <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {modules.map((m) => (
      <li>
        <ModuleCard slug={m.slug} title={m.data.title} duration={m.data.duration} xp={m.data.xp} order={m.data.order} parcours={m.data.parcours} />
      </li>
    ))}
  </ul>
</AcademyLayout>

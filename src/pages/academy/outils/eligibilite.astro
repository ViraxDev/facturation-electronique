---
import AcademyLayout from "@/layouts/AcademyLayout.astro";
import EligibiliteSimulator from "@/components/tools/EligibiliteSimulator";
---
<AcademyLayout seo={{ title: "Simulateur d'éligibilité — Facturation Électronique 2026", description: "6 questions pour connaître vos obligations et dates butoirs." }}>
  <header class="mb-6 max-w-3xl">
    <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-primary)]">Suis-je concerné par la réforme ?</h1>
    <p class="mt-3 text-[var(--color-muted-foreground)]">6 questions rapides — résultat instantané.</p>
  </header>
  <div class="max-w-3xl"><EligibiliteSimulator client:load /></div>
</AcademyLayout>

---
import AcademyLayout from "@/layouts/AcademyLayout.astro";
import ComparateurPA from "@/components/tools/ComparateurPA";
---
<AcademyLayout seo={{ title: "Comparateur de Plateformes Agréées", description: "Comparez les Plateformes Agréées (PA) immatriculées par la DGFiP." }}>
  <header class="mb-6 max-w-3xl">
    <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-primary)]">Comparateur de Plateformes Agréées</h1>
    <p class="mt-3 text-[var(--color-muted-foreground)]">Filtrez selon votre profil — cibles, API, intégration comptable.</p>
  </header>
  <ComparateurPA client:load />
</AcademyLayout>

---
import AcademyLayout from "@/layouts/AcademyLayout.astro";
import LevelIndicator from "@/components/academy/LevelIndicator";
import ParcoursProgress from "@/components/academy/ParcoursProgress";
import BadgeGrid from "@/components/academy/BadgeGrid";
---
<AcademyLayout seo={{ title: "Mon profil — Academy", description: "Votre progression, vos badges et votre niveau." }}>
  <header class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-primary)] tracking-tight">Mon profil</h1>
    <p class="mt-3 text-[var(--color-muted-foreground)]">Progression conservée localement dans votre navigateur.</p>
  </header>
  <section class="mb-10"><LevelIndicator client:load /></section>
  <section class="mb-10">
    <h2 class="text-xl font-semibold mb-4">Parcours</h2>
    <ParcoursProgress client:load />
  </section>
  <section>
    <h2 class="text-xl font-semibold mb-4">Badges</h2>
    <BadgeGrid client:load />
  </section>
</AcademyLayout>

---
import { getCollection } from "astro:content";
import AcademyLayout from "@/layouts/AcademyLayout.astro";

const entries = (await getCollection("glossaire")).sort((a, b) => a.data.terme.localeCompare(b.data.terme, "fr"));
const byCat: Record<string, typeof entries> = {};
for (const e of entries) { (byCat[e.data.categorie] ??= []).push(e); }
const cats = Object.keys(byCat).sort();
---
<AcademyLayout seo={{ title: "Lexique", description: "Glossaire expert de la facturation électronique française : 40 termes." }}>
  <header class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-primary)] tracking-tight">Lexique</h1>
    <p class="mt-3 text-lg text-[var(--color-muted-foreground)]">{entries.length} termes classés par catégorie.</p>
  </header>
  {cats.map((cat) => (
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-[var(--color-primary)] mb-4">{cat}</h2>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {byCat[cat].map(async (e) => {
          const { Content } = await e.render();
          return (
            <li class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-card)] p-5">
              <h3 class="font-bold text-[var(--color-primary)]">
                {e.data.terme}
                {e.data.acronyme_de && <span class="ml-2 text-xs text-[var(--color-muted-foreground)] font-normal">({e.data.acronyme_de})</span>}
              </h3>
              <div class="mt-2 prose prose-sm max-w-none text-[var(--color-secondary)]"><Content /></div>
            </li>
          );
        })}
      </ul>
    </section>
  ))}
</AcademyLayout>

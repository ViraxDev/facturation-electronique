---
import { getCollection, getEntry } from "astro:content";
import ModuleLayout from "@/layouts/ModuleLayout.astro";

export async function getStaticPaths() {
  const modules = await getCollection("modules");
  return modules.map((m) => ({ params: { slug: m.slug }, props: { slug: m.slug } }));
}

const { slug } = Astro.props;
const entry = await getEntry("modules", slug);
if (!entry) throw new Error(`Module not found: ${slug}`);
const { Content } = await entry.render();
---
<ModuleLayout entry={entry}>
  <Content />
</ModuleLayout>

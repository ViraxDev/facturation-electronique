---
import { getCollection } from "astro:content";
import AcademyLayout from "@/layouts/AcademyLayout.astro";

const entries = (await getCollection("veille")).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const colors: Record<string, string> = {
  fondateur: "bg-red-100 text-red-900",
  majeur: "bg-amber-100 text-amber-900",
  notable: "bg-sky-100 text-sky-900",
  mineur: "bg-slate-100 text-slate-700",
};
---
<AcademyLayout seo={{ title: "Veille — Timeline de la réforme", description: "Tous les jalons législatifs et techniques de la facturation électronique française." }}>
  <header class="mb-8">
    <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-primary)] tracking-tight">Timeline de la réforme</h1>
    <p class="mt-3 text-lg text-[var(--color-muted-foreground)]">De 2019 à 2027 : législation, normes, écosystème.</p>
  </header>
  <ol class="relative border-l-2 border-[var(--color-border)] pl-6 space-y-6">
    {entries.map(async (e) => {
      const { Content } = await e.render();
      return (
        <li class="relative">
          <span class="absolute -left-[31px] top-1.5 h-4 w-4 rounded-full bg-[var(--color-accent)] border-4 border-[var(--color-background)]" aria-hidden="true"></span>
          <div class="flex items-center gap-2 text-xs text-[var(--color-muted-foreground)] mb-1 tabular">
            <time>{e.data.date.toLocaleDateString("fr-FR", { year: "numeric", month: "long", day: "numeric" })}</time>
            <span class={`rounded-full px-2 py-0.5 font-semibold ${colors[e.data.importance] ?? "bg-slate-100"}`}>{e.data.importance}</span>
            <span class="rounded-full bg-[var(--color-muted)] px-2 py-0.5">{e.data.categorie}</span>
          </div>
          <h3 class="font-semibold text-[var(--color-primary)]">{e.data.titre}</h3>
          <div class="mt-2 prose prose-sm max-w-none"><Content /></div>
          <a href={e.data.source.url} target="_blank" rel="noopener" class="mt-2 inline-block text-xs text-[var(--color-accent)] hover:underline">Source : {e.data.source.label} ↗</a>
        </li>
      );
    })}
  </ol>
</AcademyLayout>

---
import { getCollection } from "astro:content";
import AcademyLayout from "@/layouts/AcademyLayout.astro";
import ParcoursProgress from "@/components/academy/ParcoursProgress";
import LevelIndicator from "@/components/academy/LevelIndicator";
import { ArrowRight, Scale, Network, Code2, BarChart3, Briefcase, BookOpen, Trophy, Flame, Target } from "lucide-react";

const parcours = (await getCollection("parcours")).sort((a, b) => a.data.order - b.data.order);
const modules = await getCollection("modules");
const countByParcours: Record<string, number> = {};
for (const m of modules) countByParcours[m.data.parcours] = (countByParcours[m.data.parcours] ?? 0) + 1;

const iconMap: Record<string, any> = { Scale, Network, Code2, BarChart3, Briefcase };
---
<AcademyLayout seo={{ title: "Academy — Facturation Électronique", description: "30 modules gamifiés pour maîtriser la réforme." }}>
  <header class="mb-10 max-w-3xl">
    <span class="eyebrow">Academy · 30 modules · 5 parcours</span>
    <h1 class="mt-4 text-4xl sm:text-5xl font-bold text-[var(--color-primary)] tracking-[-0.025em] leading-[1.05]">Devenez expert de la réforme.<br/><span class="text-gradient-sky">Un parcours à la fois.</span></h1>
    <p class="mt-4 text-lg text-[var(--color-muted-foreground)] leading-snug">Progressez à votre rythme, gagnez de l'XP et décrochez des certifications téléchargeables.</p>
  </header>

  <section class="mb-10 grid grid-cols-2 lg:grid-cols-4 gap-4">
    <div class="rounded-2xl bg-gradient-to-br from-[#FBBF24] to-[#F59E0B] p-5 text-white shadow-[0_8px_24px_-8px_rgb(245_158_11/0.45)]">
      <Trophy className="h-5 w-5 opacity-90" aria-hidden="true"/>
      <div class="mt-3"><LevelIndicator client:load /></div>
    </div>
    <div class="rounded-2xl border border-[var(--color-border)] bg-white p-5">
      <BookOpen className="h-5 w-5 text-[var(--color-accent)]" aria-hidden="true"/>
      <div class="mt-3 text-3xl font-bold tabular tracking-[-0.02em] text-[var(--color-primary)]">{modules.length}</div>
      <div class="text-xs text-[var(--color-muted-foreground)] mt-0.5">Modules disponibles</div>
    </div>
    <div class="rounded-2xl border border-[var(--color-border)] bg-white p-5">
      <Target className="h-5 w-5 text-[#7C3AED]" aria-hidden="true"/>
      <div class="mt-3 text-3xl font-bold tabular tracking-[-0.02em] text-[var(--color-primary)]">5</div>
      <div class="text-xs text-[var(--color-muted-foreground)] mt-0.5">Parcours certifiants</div>
    </div>
    <div class="rounded-2xl border border-[var(--color-border)] bg-white p-5">
      <Flame className="h-5 w-5 text-[#059669]" aria-hidden="true"/>
      <div class="mt-3 text-3xl font-bold tabular tracking-[-0.02em] text-[var(--color-primary)]">4</div>
      <div class="text-xs text-[var(--color-muted-foreground)] mt-0.5">Outils interactifs</div>
    </div>
  </section>

  <section class="mb-10">
    <h2 class="text-xl font-bold mb-4 text-[var(--color-primary)]">Votre progression</h2>
    <div class="rounded-2xl border border-[var(--color-border)] bg-white p-6">
      <ParcoursProgress client:load />
    </div>
  </section>

  <section>
    <h2 class="text-xl font-bold mb-4 text-[var(--color-primary)]">Les 5 parcours</h2>
    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {parcours.map((p) => {
        const Icon = iconMap[p.data.icone] ?? BookOpen;
        return (
        <li>
          <a href={`/academy/parcours/${p.data.id}`} class="group block rounded-2xl border border-[var(--color-border)] bg-white p-6 shadow-[var(--shadow-subtle)] hover:shadow-[var(--shadow-card)] transition-all hover:-translate-y-0.5">
            <div class="flex items-center justify-between">
              <div class="inline-flex h-11 w-11 items-center justify-center rounded-xl text-white" style={`background: linear-gradient(135deg, ${p.data.couleur}, ${p.data.couleur}dd)`}>
                <Icon className="h-5 w-5" aria-hidden="true"/>
              </div>
              <span class="text-[11px] font-bold uppercase tracking-[0.06em] text-[var(--color-muted-foreground)]">P{p.data.order}</span>
            </div>
            <h3 class="mt-4 text-lg font-bold text-[var(--color-primary)] group-hover:text-[var(--color-accent)] transition-colors">{p.data.titre}</h3>
            <p class="mt-1.5 text-sm text-[var(--color-muted-foreground)] leading-snug line-clamp-2">{p.data.description}</p>
            <div class="mt-5 pt-4 border-t border-[var(--color-border)] flex items-center justify-between text-xs">
              <span class="text-[var(--color-muted-foreground)] font-medium">{countByParcours[p.data.id] ?? 0} modules</span>
              <span class="inline-flex items-center gap-1 text-[var(--color-accent)] font-bold group-hover:translate-x-0.5 transition-transform">Explorer <ArrowRight className="h-3.5 w-3.5" aria-hidden="true"/></span>
            </div>
          </a>
        </li>
      )})}
    </ul>
  </section>
</AcademyLayout>

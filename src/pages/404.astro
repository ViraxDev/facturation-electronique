---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
---
<MarketingLayout seo={{ title: "Page introuvable", description: "La page demandée n'existe pas." }}>
  <section class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8 py-24 text-center">
    <p class="text-6xl font-bold text-[var(--color-accent)]">404</p>
    <h1 class="mt-4 text-2xl font-bold text-[var(--color-primary)]">Page introuvable</h1>
    <p class="mt-3 text-[var(--color-muted-foreground)]">Le lien que vous avez suivi est peut-être cassé.</p>
    <a href="/" class="mt-8 inline-flex items-center gap-2 rounded-lg bg-[var(--color-primary)] text-white px-5 py-3 text-sm font-semibold">Retour à l'accueil</a>
  </section>
</MarketingLayout>

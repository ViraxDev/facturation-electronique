---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import { Check, ArrowRight } from "lucide-react";

const plans = [
  { name: "Starter", price: "490 €", sub: "setup unique + 19 €/mois/client", features: ["Audit rapide du cabinet", "1 demi-journée de formation", "Kit commercial (scripts + pitch deck)", "Support email"], cta: "Essayer", highlighted: false },
  { name: "Pro", price: "1 490 €", sub: "setup + 25 €/mois/client, marge cabinet 40 %", features: ["Audit 360° détaillé", "2 jours de formation équipe", "Kit commercial complet + contrats", "Accompagnement 3 premiers clients", "Support prioritaire"], cta: "Recommandé", highlighted: true },
  { name: "Expert", price: "3 900 €", sub: "sur mesure, marge cabinet 50 %", features: ["Tout le pack Pro", "Intégration ERP sur mesure", "Webinars mensuels co-brandés", "Account manager dédié", "SLA 4h ouvrées"], cta: "Nous contacter", highlighted: false },
];
---
<MarketingLayout seo={{ title: "Offres & tarifs", description: "3 packs pour cabinets : Starter, Pro, Expert." }}>
  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center max-w-2xl mx-auto">
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-[var(--color-primary)]">Offres cabinet</h1>
      <p class="mt-4 text-lg text-[var(--color-muted-foreground)]">3 packs, marge cabinet jusqu'à 50 %, accompagnement concret.</p>
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
      {plans.map((p) => (
        <div class={`rounded-2xl border p-6 flex flex-col ${p.highlighted ? "border-[var(--color-accent)] bg-gradient-to-br from-sky-50 to-white shadow-lg scale-[1.02]" : "border-[var(--color-border)] bg-[var(--color-card)]"}`}>
          {p.highlighted && <span class="self-start rounded-full bg-[var(--color-accent)] text-white px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide mb-2">Recommandé</span>}
          <h3 class="text-xl font-bold text-[var(--color-primary)]">{p.name}</h3>
          <div class="mt-3"><span class="text-4xl font-bold tabular text-[var(--color-primary)]">{p.price}</span></div>
          <p class="mt-1 text-xs text-[var(--color-muted-foreground)]">{p.sub}</p>
          <ul class="mt-6 space-y-2 text-sm flex-1">
            {p.features.map((f) => <li class="flex gap-2"><Check className="h-4 w-4 text-emerald-600 flex-shrink-0 mt-0.5" aria-hidden="true"/><span>{f}</span></li>)}
          </ul>
          <a href="/contact" class={`mt-8 inline-flex items-center justify-center gap-2 rounded-lg px-5 py-3 text-sm font-semibold ${p.highlighted ? "btn-primary text-white" : "border border-[var(--color-border)] hover:bg-[var(--color-muted)]"}`}>{p.cta} <ArrowRight className="h-4 w-4" aria-hidden="true"/></a>
        </div>
      ))}
    </div>
  </section>
</MarketingLayout>

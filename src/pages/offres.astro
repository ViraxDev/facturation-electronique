---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
import { Check, ArrowRight } from "lucide-react";

const plans = [
  {
    name: "Audit technique",
    price: "À partir de 1 490 €",
    suffix: "forfait",
    sub: "Diagnostic express du SI client",
    features: [
      "Cartographie ERP / logiciels métier",
      "Choix de la Plateforme Agréée adaptée",
      "Plan de migration chiffré et daté",
      "Livrable PDF co-signable avec le cabinet",
    ],
    cta: "Demander un audit",
    highlighted: false,
  },
  {
    name: "Intégration clé en main",
    price: "À partir de 4 900 €",
    suffix: "forfait",
    sub: "Le plus choisi par les cabinets partenaires",
    features: [
      "Connecteur ERP ↔ Plateforme Agréée",
      "Génération Factur-X + mapping EN 16931",
      "Recette complète sur jeu de factures",
      "Documentation + formation 2 h équipe client",
      "Support post-déploiement 30 jours",
    ],
    cta: "Cadrer le projet",
    highlighted: true,
  },
  {
    name: "Développement sur mesure",
    price: "650 € / jour",
    suffix: "TJM",
    sub: "Connecteurs atypiques, e-reporting complexe",
    features: [
      "Développement API / webhooks spécifiques",
      "E-reporting B2C ou international",
      "Intégration ERP legacy (sur devis)",
      "Astreinte et SLA négociables",
    ],
    cta: "Discuter du besoin",
    highlighted: false,
  },
];
---
<MarketingLayout seo={{ title: "Prestations — Facturation Électronique", description: "Audit, intégration forfait ou TJM sur-mesure pour la réforme." }}>
  <section class="bg-hero-sky">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-16 pb-10 text-center">
      <span class="eyebrow">Prestations d'intégration</span>
      <h1 class="mt-5 text-[40px] sm:text-5xl font-bold tracking-[-0.025em] text-[var(--color-primary)] leading-[1.05]">Trois formats.<br/><span class="text-gradient-sky">Toujours livrés, jamais facturés à vide.</span></h1>
      <p class="mt-5 text-lg text-[var(--color-muted-foreground)] max-w-xl mx-auto leading-snug">Tarifs publics pour les cabinets partenaires. Marge cabinet conservée en co-traitance, apport d'affaires en option (15 %).</p>
    </div>
  </section>

  <section class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-20 -mt-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {plans.map((p) => (
        <div class:list={["relative rounded-[22px] p-7 flex flex-col bg-white", p.highlighted ? "border-2 border-[#0284C7] shadow-[var(--shadow-feat)]" : "border border-[var(--color-border)] shadow-[var(--shadow-subtle)]"]}>
          {p.highlighted && <span class="absolute -top-3 left-1/2 -translate-x-1/2 inline-flex rounded-full bg-gradient-to-r from-[#0369A1] to-[#0284C7] text-white px-3 py-1 text-[11px] font-bold uppercase tracking-[0.06em] shadow-[var(--shadow-subtle)]">Recommandé</span>}
          <h3 class="text-lg font-bold text-[var(--color-primary)]">{p.name}</h3>
          <p class="mt-1 text-xs text-[var(--color-muted-foreground)]">{p.sub}</p>
          <div class="mt-5 flex items-baseline gap-1.5">
            <span class="text-[28px] font-bold tabular leading-none tracking-[-0.02em] text-[var(--color-primary)]">{p.price}</span>
            {p.suffix && <span class="text-xs text-[var(--color-muted-foreground)]">{p.suffix}</span>}
          </div>
          <ul class="mt-6 space-y-2.5 text-[14px] flex-1">
            {p.features.map((f) => <li class="flex gap-2.5 items-start"><Check className="h-4 w-4 text-emerald-600 flex-shrink-0 mt-0.5" strokeWidth={3} aria-hidden="true"/><span class="text-[var(--color-secondary)]">{f}</span></li>)}
          </ul>
          <a href="/contact" class:list={["mt-7 inline-flex items-center justify-center gap-2 rounded-xl px-5 py-3 text-sm font-semibold", p.highlighted ? "btn-primary text-white" : "border border-[var(--color-border)] bg-white hover:bg-[var(--color-muted)] text-[var(--color-primary)]"]}>{p.cta} <ArrowRight className="h-4 w-4" aria-hidden="true"/></a>
        </div>
      ))}
    </div>

    <p class="mt-10 text-center text-xs text-[var(--color-muted-foreground)]">Tous les prix sont hors taxes. Devis ferme sous 48 h. Conditions partenaires cabinet disponibles sur demande.</p>
  </section>
</MarketingLayout>
